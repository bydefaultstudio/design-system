# Netlify Functions environment variables
#
# These are set on the production Netlify site and are auto-injected
# into `netlify dev` after running `npx netlify link`. This file is
# documentation only — do not commit a populated `.env`.

NOTION_API_KEY=
NOTION_DATABASE_ID_NEW_CAMPAIGN=
NOTION_DATABASE_ID_NEW_PROPOSAL=
NOTION_DATABASE_ID_FEEDBACK=
NOTION_DATABASE_ID_ACCESS_SUPPORT=
