{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash(grep *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(echo *)",
      "Bash(wc *)",
      "Bash(diff *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(jq *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(touch *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(file *)",
      "Bash(tree *)",
      "Bash(basename *)",
      "Bash(dirname *)",
      "Bash(curl -s *)",
      "Bash(curl -I *)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git ls-files *)",
      "Bash(git show *)",
      "Bash(git mv *)",
      "Bash(git stash *)",
      "Bash(git restore --staged *)",
      "Bash(node *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(cd *)"
    ],
    "deny": [
      "Bash(git push *)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)",
      "Bash(rm -rf *)",
      "Bash(sudo *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command' | grep -qE '^\\s*git\\s+commit\\b' && echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PostToolUse\",\"additionalContext\":\"IMPORTANT: A git commit just succeeded. You MUST now use AskUserQuestion to ask the user whether they want to push to the remote branch. Do not skip this step.\"}}' || true"
          }
        ]
      }
    ]
  }
}
